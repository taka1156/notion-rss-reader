{
  "name": "notion-rss-reader",
  "version": "1.0.0",
  "description": "A simple RSS reader for Notion",
  "main": "dist/index.js",
  "scripts": {
    "ci": "yarn --frozen-lockfile",
    "prepare": "husky",
    "check": "tsc --noEmit",
    "build": "tsc",
    "start": "ts-node src/index.ts",
    "start:reset": "ts-node src/index.ts --reset",
    "start:dev": "ts-node src/index.ts --debug",
    "test": "vitest run",
    "lint": "biome check src/**/*.ts",
    "lint:fix": "biome check src/**/*.ts --write",
    "pre-commit": "lint-staged && tsc --noEmit"
  },
  "dependencies": {
    "@notionhq/client": "^5.15.0",
    "cross-fetch": "^4.1.0",
    "dotenv": "^17.3.1",
    "fast-xml-parser": "^4.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^25.5.0",
    "commitizen": "^4.3.1",
    "cz-customizable": "^7.5.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-customizable"
    }
  }
}
