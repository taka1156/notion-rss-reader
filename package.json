{
  "name": "notion-rss-reader",
  "version": "1.0.0",
  "private": true,
  "description": "A simple RSS reader for Notion",
  "scripts": {
    "prepare": "husky",
    "build": "pnpm -r build",
    "test": "vitest run",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "pre-commit": "lint-staged"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "commitizen": "^4.3.1",
    "cz-customizable": "^7.5.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "vitest": "^4.1.2"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-customizable"
    }
  }
}
