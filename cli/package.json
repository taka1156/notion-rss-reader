{
  "name": "@notion-rss-reader/cli",
  "version": "1.0.0",
  "description": "A simple RSS reader for Notion",
  "main": "dist/index.js",
  "scripts": {
    "check": "tsc --noEmit",
    "build": "tsc",
    "start": "ts-node src/index.ts",
    "start:reset": "ts-node src/index.ts --reset",
    "start:dev": "ts-node src/index.ts --debug"
  },
  "dependencies": {
    "@notionhq/client": "^5.15.0",
    "cross-fetch": "^4.1.0",
    "dotenv": "^17.3.1",
    "fast-xml-parser": "^4.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
